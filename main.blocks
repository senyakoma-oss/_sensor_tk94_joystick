<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id=",ruCgA_f@-uq*K`t/)^4" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="40Wm,gvzh9vl4Gq;;q:D"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace joystick_TK94 {" line1="    /**" line2="     * Определяет состояние джойстика" line3="     */" line4="    //% block=&quot;joystick state %sensor&quot;" line5="    //% sensor.min=0 sensor.max=1023" line6="    export function joystickState(sensor: number): string {" line7="        let joystickStateResult = &quot;Steady&quot;" line8="" line9="        if (sensor &gt; 50 &amp;&amp; sensor &lt; 150) {" line10="            joystickStateResult = &quot;Up&quot;" line11="        } else if (sensor &gt; 1000) {" line12="            joystickStateResult = &quot;Right&quot;" line13="        } else if (sensor &gt; 450 &amp;&amp; sensor &lt; 550) {" line14="            joystickStateResult = &quot;Down&quot;" line15="        } else if (sensor &gt; 250 &amp;&amp; sensor &lt; 350) {" line16="            joystickStateResult = &quot;Left&quot;" line17="        } else if (sensor &gt; 150 &amp;&amp; sensor &lt; 250) {" line18="            joystickStateResult = &quot;Pressed&quot;" line19="        }" line20="" line21="        return joystickStateResult" line22="    }" line23="}" numlines="24"></mutation></block></statement></block></xml>